# .env.example - Шаблон файла переменных окружения
# Скопируйте этот файл в .env и заполните своими значениями

# URL вашего Synapse сервера
# Если Synapse в том же docker-compose, используйте: http://synapse:8008
# Если Synapse на отдельном сервере: http://<ip-адрес>:8008 или https://matrix.your-domain.com
SYNAPSE_ADMIN_URL=http://synapse:8008

# Имя вашего Matrix сервера (домен)
MATRIX_SERVER_NAME=your-domain.com

# Токен администратора Synapse
# Способ 1: Через registration_shared_secret в homeserver.yaml
# Добавьте в конфиг synapse: registration_shared_secret: "your-secret-key"
# Затем получите токен: 
# curl -X POST 'http://localhost:8008/_synapse/admin/v1/login' \
#   -H 'Content-Type: application/json' \
#   -d '{"type":"login_token","user":"@admin:your-domain.com","password":"your-password"}'
#
# Способ 2: Создать токен через Admin API
# curl -X POST 'http://localhost:8008/_synapse/admin/v1/users/@admin:your-domain.com/login' \
#   -H 'Authorization: Bearer <admin-token>' \
#   -H 'Content-Type: application/json' \
#   -d '{}'
SYNAPSE_ADMIN_ACCESS_TOKEN=your-admin-access-token-here

# Секретный ключ для сессий Flask (сгенерируйте случайную строку)
# Можно использовать: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=super-secret-key-change-me-in-production

# Путь к базе данных внутри контейнера (не меняйте, если не знаете что делаете)
DATABASE_URL=/app/data/codes.db
