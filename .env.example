# .env.example - Шаблон файла переменных окружения
# Скопируйте этот файл в .env и заполните своими значениями

# URL вашего Synapse сервера
# Если Synapse в том же docker-compose, используйте: http://synapse:8008
# Если Synapse на отдельном сервере: http://<ip-адрес>:8008 или https://matrix.your-domain.com
SYNAPSE_URL=http://synapse:8008

# Имя вашего Matrix сервера (домен)
MATRIX_SERVER_NAME=your-domain.com

# Секретный ключ для сессий Flask (сгенерируйте случайную строку)
# Можно использовать: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=super-secret-key-change-me-in-production
